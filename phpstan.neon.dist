includes:
    - vendor/larastan/larastan/extension.neon
    # Existing level 3 findings are captured here so new findings fail analysis.
    - phpstan-baseline.neon

parameters:
    level: 3

    paths:
        - app
        - config
        - routes
        - database/factories
        - database/seeders
        - tests

    excludePaths:
        analyse:
            - bootstrap/cache
            - node_modules
            - public/build
            - storage
            - vendor

    parallel:
        maximumNumberOfProcesses: 1

    tmpDir: storage/framework/cache/phpstan
