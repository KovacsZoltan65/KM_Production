{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "i18n:check": "node scripts/check-translations.js",
        "test": "npm run test:frontend",
        "test:frontend": "vitest run",
        "test:frontend:watch": "vitest",
        "test:frontend:coverage": "vitest run --coverage",
        "test:e2e": "npm run test:e2e:prepare && npm run build && playwright test",
        "test:e2e:prepare": "node scripts/prepare-e2e.js",
        "test:e2e:install": "playwright install chromium firefox webkit",
        "test:e2e:a11y": "playwright test --project=chromium tests/e2e/accessibility",
        "test:e2e:keyboard": "playwright test --project=chromium tests/e2e/keyboard",
        "test:e2e:cross-browser": "playwright test --project=firefox --project=webkit tests/e2e/smoke/cross-browser.spec.js",
        "test:e2e:mobile": "playwright test --project=mobile-chromium tests/e2e/smoke/mobile.spec.js",
        "test:e2e:ui": "npm run test:e2e:prepare && npm run build && playwright test --ui",
        "test:e2e:headed": "npm run test:e2e:prepare && npm run build && playwright test --headed",
        "test:e2e:report": "playwright show-report"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.10",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.1",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.4.0",
        "@primeuix/themes": "^2.0.3",
        "@tanstack/vue-table": "^8.21.3",
        "@vuelidate/core": "^2.0.3",
        "@vuelidate/validators": "^2.0.4",
        "@vueuse/head": "^2.0.0",
        "axios": "^1.18.0",
        "laravel-vue-i18n": "^2.8.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "tailwindcss-primeui": "^0.6.1",
        "uuid": "^14.0.1",
        "vue": "^3.5.38"
    }
}
