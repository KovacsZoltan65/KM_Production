APP_NAME="KM Production Testing"
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=false
APP_URL=http://127.0.0.1
APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# A composer test:backend:sqlite parancs ezeket a biztonságos értékeket kényszeríti ki.
DB_CONNECTION=sqlite
DB_DATABASE=:memory:
DB_FOREIGN_KEYS=true
DB_URL=

# A MySQL wrapper kizárólag ezeket a TEST_MYSQL_* értékeket olvassa.
# A compose.testing.yml alapértékeihez nem szükséges felülírni őket.
TEST_MYSQL_HOST=127.0.0.1
TEST_MYSQL_PORT=33060
TEST_MYSQL_DATABASE=km_production_testing
TEST_MYSQL_USERNAME=km_testing
TEST_MYSQL_PASSWORD=testing_only

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_TIMEZONE=+00:00

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=null
MAIL_MAILER=array
FILESYSTEM_DISK=testing
BROADCAST_CONNECTION=log

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
