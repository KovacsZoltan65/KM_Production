APP_NAME="KM Production E2E"
APP_ENV=e2e
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8001
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/e2e.sqlite

SESSION_DRIVER=database
SESSION_COOKIE=km-production-e2e-session
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
FILESYSTEM_DISK=e2e

BROADCAST_CONNECTION=null
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
